{
  "name": "voidink",
  "version": "0.1.0",
  "private": true,
  "description": "Indie horror review emotion map — multi-label emotion classification",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "lint": "npm run lint --workspace=web",
    "dev:api": "cd apps/api && python -m uvicorn voidink_api.main:app --reload --port 8000",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
